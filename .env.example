# ─── Entorno ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Base de datos ────────────────────────────────────────────────────────────
NEON_DB_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── CORS / Frontends permitidos ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (Brevo) ────────────────────────────────────────────────────────────
ADMIN_EMAIL=
EMAIL_FROM=

# AURA 2070 (OpenAI - solo backend)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=
OPENAI_IMAGE_QUALITY=high
OPENAI_MODERATION_MODEL=omni-moderation-latest
# Cuota persistente por tenant/día. Ajustar según el plan comercial.
AURA_DAILY_REQUEST_LIMIT=100
AURA_OPENAI_TIMEOUT_MS=18000
AURA_MOCK_PROVIDER_ENABLED=false
AURA_STAGING_MODE=false
AURA_CONVERSATION_RETENTION_DAYS=180
AURA_IMAGE_MAX_JOBS_PER_DAY=20
AURA_IMAGE_WORKER_ENABLED=false
AURA_IMAGE_WORKER_POLL_MS=5000
AURA_IMAGE_STALE_JOB_MINUTES=15
AURA_NOTIFICATION_WORKER_ENABLED=false
AURA_NOTIFICATION_WORKER_CRON=*/30 * * * * *
AURA_NOTIFICATION_BATCH_SIZE=20
AURA_NOTIFICATION_WORKER_TIMEOUT_MS=60000
AURA_NOTIFICATION_STALE_JOB_MINUTES=15
AURA_NOTIFICATION_MOCK_PROVIDER_ENABLED=false
LEGACY_CREDIT_REMINDER_WORKER_ENABLED=false
LEGACY_NOTIFICATION_SCHEDULER_ENABLED=false
AURA_IMAGE_OPENAI_TIMEOUT_MS=90000
AURA_IMAGE_MOCK_PROVIDER_ENABLED=false
AURA_IMAGE_MAX_OUTPUT_MB=10
AURA_IMAGE_USD_PER_IMAGE=0
AURA_ACTION_EXPIRY_HOURS=24
AURA_PREDICTIVE_JOBS_ENABLED=false
AURA_PREDICTIVE_DAILY_CRON=20 2 * * *
AURA_FORECAST_WORKER_ENABLED=false
AURA_FORECAST_WORKER_CRON=*/5 * * * *
AURA_FORECAST_WORKER_BATCH=5
AURA_FORECAST_STALE_JOB_MINUTES=30
AURA_PREDICTION_FRESHNESS_HOURS=48
AURA_SEND_TIME_MIN_OBSERVATIONS=30
AURA_SEND_TIME_MIN_CAMPAIGNS=2
AURA_SEND_TIME_LOOKBACK_DAYS=180
AURA_VOICE_ENABLED=false
AURA_VOICE_CLEANUP_ENABLED=false
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TTS_FORMAT=mp3
AURA_VOICE_MAX_AUDIO_MB=10
AURA_VOICE_MAX_DURATION_SECONDS=60
AURA_VOICE_MAX_TRANSCRIPT_CHARS=2000
AURA_VOICE_SESSION_TTL_SECONDS=600
AURA_VOICE_RETENTION_HOURS=24
AURA_VOICE_OPENAI_TIMEOUT_MS=30000
AURA_VOICE_MOCK_PROVIDER_ENABLED=false
AURA_VOICE_MOCK_TRANSCRIPT=Resume las ventas del dia
# Tarifas USD por un millón de tokens para costo estimado; actualizar al cambiar modelo.
AURA_INPUT_USD_PER_1M=0
AURA_OUTPUT_USD_PER_1M=0

# Legacy Agent (deprecated)
# Mantener apagado. Solo para pruebas locales controladas, con tenants explicitos.
ENABLE_LEGACY_AGENT_CRON=false
LEGACY_AGENT_CRON_TENANT_IDS=
ENABLE_LEGACY_AGENT_SQL=false

# ─── Push notifications (VAPID) ──────────────────────────────────────────────
# Genera con: npx web-push generate-vapid-keys
VAPID_EMAIL=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Wompi (pagos) ───────────────────────────────────────────────────────────
# Las credenciales de Wompi ya NO se usan globalmente.
# Cada tienda conecta su propia cuenta vía POST /api/payment-accounts.
# Estas variables son solo para referencia o fallback transitorio (ver README).
WOMPI_ENV=test
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=

# Wompi base URLs (no cambiar salvo entornos custom)
WOMPI_SANDBOX_URL=https://sandbox.wompi.co/v1
WOMPI_PRODUCTION_URL=https://production.wompi.co/v1

# ─── Cifrado de credenciales de pasarela ──────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Debe ser exactamente 32 bytes (64 chars hex o 44 chars base64). NUNCA dejar vacío en prod.
PAYMENTS_ENCRYPTION_KEY=

# ─── Setup inicial (deshabilitar o dejar vacío en producción) ─────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETUP_SECRET_KEY=

# ─── Pool de base de datos ───────────────────────────────────────────────────
DB_POOL_MAX=10

# ─── Configuración de peticiones ─────────────────────────────────────────────
REQUEST_LIMIT=10mb
REQUEST_TIMEOUT=30000

# ─── Intentos de login ────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MINUTES=15

# ─── Logs ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── WhatsApp (notificaciones al admin del tenant) ───────────────────────────
# Elige el proveedor: 'meta_cloud' (sin deps extra) o 'twilio'
WHATSAPP_PROVIDER=meta_cloud
# En campanas WhatsApp, mantener true salvo pruebas controladas: proveedores suelen exigir templates aprobados.
WHATSAPP_REQUIRE_TEMPLATES=true

# — Meta Cloud API (proveedor: meta_cloud) ────────────────────────────────────
# Panel: developers.facebook.com → tu app → WhatsApp → API Setup
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_BUSINESS_ACCOUNT_ID=
# App Secret (Settings → Basic) — requerido para verificar firma HMAC del webhook
META_WA_APP_SECRET=
# Token de verificación para el webhook — genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
META_WA_VERIFY_TOKEN=

# — Twilio (proveedor: twilio) ────────────────────────────────────────────────
# Requiere: npm install twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=+14155238886
