# ─── Entorno ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Base de datos ────────────────────────────────────────────────────────────
NEON_DB_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── CORS / Frontends permitidos ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (Brevo) ────────────────────────────────────────────────────────────
ADMIN_EMAIL=
EMAIL_FROM=

# ─── Push notifications (VAPID) ──────────────────────────────────────────────
# Genera con: npx web-push generate-vapid-keys
VAPID_EMAIL=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Wompi (pagos) ───────────────────────────────────────────────────────────
WOMPI_ENV=test
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=

# ─── Setup inicial (deshabilitar o dejar vacío en producción) ─────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETUP_SECRET_KEY=

# ─── Configuración de peticiones ─────────────────────────────────────────────
REQUEST_LIMIT=10mb
REQUEST_TIMEOUT=30000

# ─── Intentos de login ────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MINUTES=15

# ─── Logs ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
